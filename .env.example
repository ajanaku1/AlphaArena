# Database
DATABASE_URL=postgresql://user:password@localhost:5432/alpharena

# Supabase (optional - for production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Privy Authentication (optional)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Pacifica API (Trader Data - read-only)
PACIFICA_API_BASE=https://api.pacifica.io

# Pacifica Trading (order execution)
PACIFICA_TRADING_ENV=testnet
DEFAULT_SLIPPAGE_PERCENT=1
AUTO_CLOSE_SLIPPAGE_PERCENT=3

# Fuul API (Referrals)
FUUL_API_KEY=your-fuul-api-key
NEXT_PUBLIC_FUUL_API_KEY=your-fuul-api-key

# Agent Wallet Encryption (generate with: openssl rand -hex 32)
AGENT_WALLET_ENCRYPTION_KEY=your-256-bit-hex-key
